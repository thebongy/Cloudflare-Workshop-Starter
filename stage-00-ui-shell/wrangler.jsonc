{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "github-mcp-codemode-stage-00",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-28",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  }
}
